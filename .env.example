# Admin password (REQUIRED). Set this in Vercel as ADMIN_PASSWORD.
ADMIN_PASSWORD=change-me

# Upstash Redis (REQUIRED in production).
# Free tier at https://upstash.com — no credit card needed.
# In Vercel, both vars are auto-injected if you attach an Upstash Redis integration from the Storage tab.
# Locally, the app falls back to an in-memory store if these are unset (good enough for `pnpm dev`).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
